{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.png"
    },
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/google/callback",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/google/callback"
    },
    {
      "source": "/auth/google",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/google"
    },
    {
      "source": "/auth/apple/callback",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/apple/callback"
    },
    {
      "source": "/auth/apple",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/apple"
    },
    {
      "source": "/auth/linkedin/callback",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/linkedin/callback"
    },
    {
      "source": "/auth/linkedin",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/linkedin"
    },
    {
      "source": "/auth/microsoft/callback",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/microsoft/callback"
    },
    {
      "source": "/auth/microsoft",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/microsoft"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
