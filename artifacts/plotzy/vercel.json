{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://workspaceapi-server-production-14b0.up.railway.app/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

