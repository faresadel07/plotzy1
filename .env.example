# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SESSION_SECRET=generate-a-64-char-random-string-here
PORT=8080
NODE_ENV=production
ADMIN_EMAIL=your-admin@email.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── AI (required for AI features) ─────────────────────────
OPENAI_API_KEY=sk-...
# Alternative OpenAI key name (used by some integrations)
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Payments ──────────────────────────────────────────────
# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_SANDBOX=false

# ── OAuth (enables social login) ──────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Email (required for password reset) ───────────────────
RESEND_API_KEY=re_...

# ── Optional ──────────────────────────────────────────────
# Cookie SameSite policy: "lax" (default, safer) or "none" (needed if API and frontend on different domains)
# COOKIE_SAME_SITE=lax

# Frontend URL for OAuth callbacks (auto-detected in most setups)
# FRONTEND_URL=https://yourdomain.com

# Custom domain (used for OAuth callback URLs)
# APP_DOMAIN=https://yourdomain.com

# Redis cache (optional, app works without it)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
